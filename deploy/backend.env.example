# Backend (Strapi) — скопируйте в backend/.env на сервере
# Сгенерируйте секреты: openssl rand -base64 32

# Сервер
HOST=0.0.0.0
PORT=1337
FRONTEND_URL=https://taiga-development.ru

# Секреты (обязательно замените на свои!)
# APP_KEYS — в кавычках, если ключи содержат = или + (иначе "expected pattern" в Strapi)
APP_KEYS="ключ1,ключ2,ключ3,ключ4"

# Публичный URL бэкенда (без слэша в конце) — для админки и плагинов
STRAPI_ADMIN_BACKEND_URL=https://taiga-development.ru
API_TOKEN_SALT=ваш_api_token_salt
ADMIN_JWT_SECRET=ваш_admin_jwt_secret
TRANSFER_TOKEN_SALT=ваш_transfer_token_salt
JWT_SECRET=ваш_jwt_secret
ENCRYPTION_KEY=ваш_encryption_key

# База данных (SQLite)
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db

# SMTP (mail.ru) для уведомлений о заявках
# Пример для mail.ru:
# SMTP_HOST=smtp.mail.ru
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=ваш_ящик@mail.ru
# SMTP_PASS=пароль_или_app_password
# MAIL_FROM=ваш_ящик@mail.ru
# MAIL_REPLY_TO=ваш_ящик@mail.ru
# MAIL_TO=куда_получать_заявки@mail.ru

# Опционально: Bitrix24 / M2Lab для заявок
# BITRIX_WEBHOOK_URL=https://ваша_компания.bitrix24.ru/rest/1/код/crm.lead.add.json
# M2LAB_API_URL=https://api.m2lab.ru/v1/leads
# M2LAB_API_KEY=ваш_ключ_m2lab
